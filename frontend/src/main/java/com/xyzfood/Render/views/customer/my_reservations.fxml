<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.xyzfood.Render.controllers.customer.MyReservationsController">
    <top><fx:include source="../components/user_navbar.fxml"/></top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox spacing="28" styleClass="page">
                <padding><Insets top="48" right="36" bottom="40" left="36"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <HBox styleClass="page-title-row">
                        <Label styleClass="page-title-icon">
                            <graphic><FontIcon iconColor="#A78BFA" iconLiteral="fas-clipboard-list" iconSize="28"/></graphic>
                        </Label>
                        <Label text="Đơn đặt bàn của tôi" styleClass="page-title"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox fx:id="reservationsBox" spacing="18"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
