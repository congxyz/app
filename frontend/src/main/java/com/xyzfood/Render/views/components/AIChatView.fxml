<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.xyzfood.controllers.components.AIChatController"
            styleClass="ai-root">

    <top>
        <HBox styleClass="header">
            <Label text="XYZ Food AI Assistant"
                   styleClass="header-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    styleClass="chat-scroll">

            <content>
                <VBox fx:id="chatContainer"
                      spacing="10"
                      styleClass="chat-container"/>
            </content>

        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10"
              styleClass="input-container">

            <TextField fx:id="messageField"
                       promptText="Nhập câu hỏi..."
                       HBox.hgrow="ALWAYS"
                       styleClass="message-field"/>

            <Button text="➤"
                    onAction="#sendMessage"
                    styleClass="send-btn"/>
        </HBox>
    </bottom>

</BorderPane>