<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="620.0" prefWidth="840.0" style="-fx-background-color: #16213E; -fx-background-radius: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.xyzfood.Render.controllers.admin.FoodController">
   <children>
      <VBox spacing="18.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <Label fx:id="titleLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" text="Thêm món ăn mới" />
            <TextField fx:id="nameField" prefHeight="45.0" promptText="Tên món ăn" />
            <TextArea fx:id="descriptionArea" prefHeight="92.0" prefWidth="338.0" promptText="Mô tả" wrapText="true" />
            <HBox spacing="20.0">
               <children>
                  <TextField fx:id="priceField" promptText="Giá" HBox.hgrow="ALWAYS" />
                  <ComboBox fx:id="categoryBox" prefWidth="220.0" />
               </children>
            </HBox>
            <VBox spacing="10.0">
               <children>
                  <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;" text="Ảnh món ăn" />
                  <HBox spacing="12.0">
                     <children>
                        <TextField fx:id="imagePathField" editable="false" prefHeight="42.0" promptText="Chọn ảnh từ máy" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#chooseImage" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-border-color: #2b3a59; -fx-border-radius: 8; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: 800; -fx-padding: 9 16;" text="Chọn ảnh">
                           <graphic><FontIcon iconColor="white" iconLiteral="fas-image" iconSize="16" /></graphic>
                        </Button>
                     </children>
                  </HBox>
                  <ImageView fx:id="imagePreview" fitHeight="140.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" style="-fx-background-color: #0F172A;" />
               </children>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="18.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#close" prefHeight="52.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-border-color: #2b3a59; -fx-border-radius: 8; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: 800; -fx-padding: 9 16;" text="Hủy">
                     <graphic><FontIcon iconColor="white" iconLiteral="fas-times" iconSize="17" /></graphic>
                  </Button>
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#updateFood" prefHeight="52.0" prefWidth="170.0" style="-fx-background-color: #ff0a2e; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: 800; -fx-padding: 9 14; -fx-effect: dropshadow(gaussian, rgba(255,10,46,0.30), 18, 0.25, 0, 8);" text="Lưu món ăn">
                     <graphic><FontIcon iconColor="white" iconLiteral="fas-save" iconSize="17" /></graphic>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
