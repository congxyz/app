<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.String?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.xyzfood.Render.controllers.customer.CartController">
    <top><fx:include source="../components/user_navbar.fxml"/></top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox spacing="28" styleClass="page">
                <padding><Insets top="70" right="36" bottom="40" left="36"/></padding>
                <HBox styleClass="page-title-row">
                    <Label styleClass="page-title-icon">
                        <graphic><FontIcon iconColor="#FB7185" iconLiteral="fas-utensils" iconSize="28"/></graphic>
                    </Label>
                    <Label text="Thực đơn XYZ Food" styleClass="page-title"/>
                </HBox>
                <HBox spacing="10">
                    <Button text="Tất cả" userData="all" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Cơm" userData="Cơm" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Hải sản" userData="Hải sản"  onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Khai vị" userData="khai vị" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Lẩu" userData="Lẩu" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Món chính" userData="Món chính" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Mì - Phở" userData="Mì - Phở" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Nướng" userData="Nướng" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Tráng miệng" userData="Tráng miệng" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                    <Button text="Đồ uống" userData="Đồ uống" onAction="#searchforCategory" styleClass="user-nav-button user-nav-active"/>
                        
                </HBox>
                <TilePane fx:id="foodGrid" prefColumns="5" styleClass="food-grid"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
